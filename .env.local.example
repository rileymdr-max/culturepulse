# Copy this to .env.local before running `npm run dev`
# Replace values as needed for your local setup.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/culturepulse"
NEXTAUTH_SECRET="dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Leave platform keys blank — app uses mock data automatically
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="CulturePulse/1.0 (by /u/YOUR_USERNAME)"
TWITTER_BEARER_TOKEN=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_BUSINESS_ACCOUNT_ID=""
FACEBOOK_ACCESS_TOKEN=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FORCE_MOCK_DATA="true"
