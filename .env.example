# ============================================================
# CulturePulse — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# ------------------------------------------------------------
# DATABASE (PostgreSQL via Prisma)
# ------------------------------------------------------------
# Local dev example: postgresql://postgres:password@localhost:5432/culturepulse
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ------------------------------------------------------------
# NEXTAUTH
# ------------------------------------------------------------
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# The canonical URL of your deployment (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# REDDIT API
# Obtain at: https://www.reddit.com/prefs/apps
# Create a "script" app — copy client ID and secret.
# ------------------------------------------------------------
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="CulturePulse/1.0 (by /u/YOUR_REDDIT_USERNAME)"

# ------------------------------------------------------------
# X / TWITTER API v2
# Obtain at: https://developer.twitter.com/en/portal/dashboard
# You need a project + app with "Read" permissions.
# ------------------------------------------------------------
TWITTER_BEARER_TOKEN=""
TWITTER_API_KEY=""
TWITTER_API_SECRET=""
TWITTER_ACCESS_TOKEN=""
TWITTER_ACCESS_SECRET=""

# ------------------------------------------------------------
# TIKTOK RESEARCH API
# Obtain at: https://developers.tiktok.com/products/research-api
# Requires approval — US/EU academic/business accounts only.
# If not configured, the app uses mock data automatically.
# ------------------------------------------------------------
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# ------------------------------------------------------------
# INSTAGRAM GRAPH API
# Obtain at: https://developers.facebook.com
# Requires a Facebook Business account + Instagram Professional account.
# Steps:
#   1. Create a Meta App at developers.facebook.com
#   2. Add the Instagram Graph API product
#   3. Generate a long-lived User Access Token with
#      instagram_basic, instagram_manage_insights permissions
# If not configured, the app uses mock data automatically.
# ------------------------------------------------------------
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_BUSINESS_ACCOUNT_ID=""

# ------------------------------------------------------------
# FACEBOOK GRAPH API
# Same Meta App as Instagram above.
# Requires pages_read_engagement, pages_read_user_content permissions.
# If not configured, the app uses mock data automatically.
# ------------------------------------------------------------
FACEBOOK_ACCESS_TOKEN=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# ------------------------------------------------------------
# RATE LIMITING (optional — in-memory by default)
# To use Upstash Redis instead, fill these in.
# Obtain at: https://upstash.com
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
# Set to "true" to force all platforms into mock-data mode
# regardless of whether API keys are configured.
FORCE_MOCK_DATA="false"
